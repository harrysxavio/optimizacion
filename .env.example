# Slotting Optimization Engine — Environment Configuration
# Copy this file to .env and adjust values for your environment.

# Project root (auto-detected from package structure in most cases;
# override only if running scripts from unusual locations).
PROJECT_ROOT=

# Data paths (defaults to <project_root>/data/ if not set)
DATA_RAW_DIR=
DATA_PROCESSED_DIR=
DATA_SYNTHETIC_DIR=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Random seed for reproducible synthetic data generation (Phase 1+)
RANDOM_SEED=42
